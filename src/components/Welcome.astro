			<div class="stats-duo">
				<div class="stat-card reveal">
					<div class="stat-icon"><Icon name="lucide:layout" size={22} /></div>
					<div class="stat-value">60+</div>
					<div class="stat-label">prestations</div>
				</div>
				<div class="stat-card reveal">
					<div class="stat-icon"><Icon name="lucide:target" size={22} /></div>
					<div class="stat-value">29&euro;</div>
					<div class="stat-label">a partir de / mois</div>
				</div>
			</div>
		</div>
	</section>

	<!-- SECTION 2b : STATS — partie 2 -->
	<section class="snap-section stats-section stats-alt">
		<div class="parallax-bg parallax-gradient-1b"></div>
		<div class="section-content stats-layout">
			<div class="stats-duo">
				<div class="stat-card reveal">
					<div class="stat-icon"><Icon name="lucide:clock" size={22} /></div>
					<div class="stat-value">&lt;24h</div>
					<div class="stat-label">temps de reponse</div>
				</div>
				<div class="stat-card reveal">
					<div class="stat-icon"><Icon name="lucide:shield" size={22} /></div>
					<div class="stat-value">100%</div>
					<div class="stat-label">prix transparents</div>
