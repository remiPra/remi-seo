<!-- Intersection Observer for reveal + parallax -->
<script>
	// Reveal on scroll
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('revealed');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.15, rootMargin: '0px 0px -20px 0px' }
	);
	document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

	// Parallax on scroll (transform-based, works on mobile)
	const container = document.querySelector('.snap-container');
	if (container) {
		container.addEventListener('scroll', () => {
			const scrollTop = container.scrollTop;
			document.querySelectorAll('.parallax-bg').forEach((bg) => {
				const section = bg.parentElement;
				if (section) {
					const offset = section.offsetTop;
					const speed = 0.35;
					const yPos = (scrollTop - offset) * speed;
					(bg as HTMLElement).style.transform = `translate3d(0, ${yPos}px, 0)`;
				}
			});
		}, { passive: true });
	}

	// Scroll hint bounce
	const hint = document.querySelector('.scroll-hint');
	if (hint) {
		setTimeout(() => {
			hint.classList.add('bouncing');
		}, 2000);
	}
</script>

<style>
	/* ─── VARIABLES ─── */
	:root {
		--navy: #0f1b2e;
		--accent: #2563eb;
		--accent-soft: rgba(37, 99, 235, 0.07);
		--accent-hover: #1d4ed8;
		--text: #1a1a2e;
		--text-sec: #4a5568;
		--text-muted: #94a3b8;
		--border: #e2e8f0;
		--border-light: #f1f5f9;
		--bg: #ffffff;
		--bg-soft: #f8fafc;
		--radius: 12px;
	}

	/* ─── SCROLL SNAP CONTAINER ─── */
	.snap-container {
		height: 100vh;
		overflow-y: scroll;
		scroll-snap-type: y mandatory;
		scroll-behavior: smooth;
	}

	.snap-section {
		height: 100vh;
		scroll-snap-align: start;
		scroll-snap-stop: always;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	/* ─── PARALLAX BACKGROUNDS ─── */
	.parallax-bg {
		position: absolute;
		inset: -20% 0;
		pointer-events: none;
		will-change: transform;
		z-index: 0;
	}

	.hero-bg-dots {
		opacity: 0.018;
		background-image: radial-gradient(circle at 1px 1px, var(--navy) 1px, transparent 0);
		background-size: 40px 40px;
	}

	.parallax-gradient-1 {
		background: radial-gradient(ellipse at 30% 20%, rgba(37, 99, 235, 0.06) 0%, transparent 60%),
					radial-gradient(ellipse at 70% 80%, rgba(124, 58, 237, 0.04) 0%, transparent 60%);
	}

	.parallax-gradient-2 {
		background: radial-gradient(ellipse at 70% 30%, rgba(37, 99, 235, 0.05) 0%, transparent 55%),
					radial-gradient(ellipse at 20% 70%, rgba(16, 185, 129, 0.04) 0%, transparent 55%);
	}
	.parallax-gradient-2b {
		background: radial-gradient(ellipse at 30% 40%, rgba(124, 58, 237, 0.05) 0%, transparent 55%),
					radial-gradient(ellipse at 80% 70%, rgba(37, 99, 235, 0.04) 0%, transparent 50%);
	}
	.parallax-gradient-2c {
		background: radial-gradient(ellipse at 60% 25%, rgba(16, 185, 129, 0.05) 0%, transparent 55%),
					radial-gradient(ellipse at 25% 75%, rgba(37, 99, 235, 0.04) 0%, transparent 50%);
	}

	.parallax-gradient-1b {
		background: radial-gradient(ellipse at 60% 60%, rgba(37, 99, 235, 0.05) 0%, transparent 55%),
					radial-gradient(ellipse at 20% 30%, rgba(124, 58, 237, 0.03) 0%, transparent 50%);
	}

	.parallax-gradient-3 {
		background: radial-gradient(ellipse at 50% 20%, rgba(124, 58, 237, 0.06) 0%, transparent 60%),
					radial-gradient(ellipse at 30% 80%, rgba(37, 99, 235, 0.04) 0%, transparent 50%);
	}
	.parallax-gradient-3b {
		background: radial-gradient(ellipse at 70% 50%, rgba(37, 99, 235, 0.06) 0%, transparent 55%),
					radial-gradient(ellipse at 20% 30%, rgba(16, 185, 129, 0.04) 0%, transparent 50%);
	}
	.parallax-gradient-3c {
		background: radial-gradient(ellipse at 30% 40%, rgba(16, 185, 129, 0.05) 0%, transparent 55%),
					radial-gradient(ellipse at 80% 70%, rgba(124, 58, 237, 0.04) 0%, transparent 50%);
	}

	.parallax-gradient-4 {
		background: radial-gradient(ellipse at 60% 40%, rgba(37, 99, 235, 0.08) 0%, transparent 50%);
	}

	/* ─── ANIMATIONS ─── */
	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(36px); }
		to { opacity: 1; transform: translateY(0); }
	}
	@keyframes bounce {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(8px); }
	}

	.anim-fade { animation: fadeUp 2.4s cubic-bezier(0.12, 1, 0.2, 1) forwards; }
	.anim-d1 { animation-delay: 0.6s; opacity: 0; }
	.anim-d2 { animation-delay: 1.4s; opacity: 0; }
	.anim-d3 { animation-delay: 2.2s; opacity: 0; }
	.anim-d4 { animation-delay: 3.0s; opacity: 0; }

	.reveal {
		opacity: 0;
		transform: translateY(30px);
		transition: opacity 2s cubic-bezier(0.12, 1, 0.2, 1),
					transform 2s cubic-bezier(0.12, 1, 0.2, 1);
	}
	.reveal.revealed {
		opacity: 1;
		transform: translateY(0);
	}

	/* Stagger — cascade lente */
	.services-duo .reveal:nth-child(1) { transition-delay: 0.3s; }
	.services-duo .reveal:nth-child(2) { transition-delay: 0.9s; }
	.stats-duo .reveal:nth-child(1) { transition-delay: 0.3s; }
	.stats-duo .reveal:nth-child(2) { transition-delay: 0.8s; }

	/* ─── SCROLL HINT ─── */
	.scroll-hint {
		margin-top: 32px;
		color: var(--text-muted);
		opacity: 0.5;
	}
	.scroll-hint.bouncing {
		animation: bounce 1.5s ease-in-out infinite;
	}

	/* ─── NAV ─── */
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: rgba(255, 255, 255, 0.88);
		backdrop-filter: blur(20px);
		border-bottom: 1px solid var(--border-light);
	}
	.nav-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 24px;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.nav-brand {
		display: flex;
		align-items: center;
		gap: 12px;
	}
	.nav-logo {
		width: 34px;
		height: 34px;
		border-radius: 9px;
		background: var(--navy);
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 800;
		font-size: 15px;
	}
	.nav-name {
		font-weight: 700;
		font-size: 15px;
		color: var(--navy);
		letter-spacing: -0.02em;
	}
	.nav-tagline {
		font-size: 11px;
		color: var(--text-muted);
	}
	.nav-link {
		text-decoration: none;
		font-size: 13px;
		font-weight: 600;
		color: var(--text-sec);
		transition: color 0.2s;
	}
	.nav-link:hover {
		color: var(--accent);
	}
	.nav-cta {
		padding: 8px 20px;
		background: var(--navy);
		color: #fff;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 600;
		font-size: 13px;
		transition: background 0.2s, transform 0.2s;
	}
	.nav-cta:hover {
		background: var(--accent);
		transform: translateY(-1px);
	}

	/* ─── HERO ─── */
	.hero {
		background: #fff;
		text-align: center;
		padding: 60px 24px 40px;
	}
	.hero-content {
