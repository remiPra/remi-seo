<!-- Modal Quiz (rendered outside snap-container, position:fixed) -->
<EligibiliteChecker client:load />

<!-- Reveal on scroll + Anchor scroll fix -->
<script>
	// Reveal on scroll
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('revealed');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.15, rootMargin: '0px 0px -20px 0px' }
	);
	document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

	// Fix anchor links inside snap-container
	const snapContainer = document.querySelector('.snap-container');
	if (snapContainer) {
		document.querySelectorAll('a[href^="#"]').forEach((link) => {
			link.addEventListener('click', (e) => {
				const id = link.getAttribute('href')?.slice(1);
				if (!id) return;
				const target = document.getElementById(id);
				if (target && snapContainer.contains(target)) {
					e.preventDefault();
					target.scrollIntoView({ behavior: 'smooth', block: 'start' });
				}
			});
		});
	}
</script>

<style>
	/* ─── SCROLL SNAP CONTAINER ─── */
	.snap-container {
		height: 100vh;
		overflow-y: scroll;
		scroll-snap-type: y mandatory;
		scroll-behavior: smooth;
	}

	.snap-section {
		height: 100vh;
		scroll-snap-align: start;
		scroll-snap-stop: always;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	/* Inner scrollable wrapper for content-heavy sections */
	.fin-section-inner {
		width: 100%;
		max-height: 100vh;
		overflow-y: auto;
		padding: 80px 0 40px;
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	.fin-section-inner::-webkit-scrollbar {
		display: none;
	}

	/* ─── VARIABLES ─── */
	:root {
		--navy: #0f1b2e;
		--accent: #2563eb;
		--accent-soft: rgba(37, 99, 235, 0.07);
		--accent-hover: #1d4ed8;
		--text: #1a1a2e;
		--text-sec: #4a5568;
		--text-muted: #94a3b8;
		--border: #e2e8f0;
		--border-light: #f1f5f9;
		--bg: #ffffff;
		--bg-soft: #f8fafc;
		--radius: 12px;
		--green: #059669;
		--green-soft: rgba(5, 150, 105, 0.08);
	}

	/* ─── ANIMATIONS ─── */
	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(36px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.anim-fade { animation: fadeUp 2.4s cubic-bezier(0.12, 1, 0.2, 1) forwards; }
	.anim-d1 { animation-delay: 0.6s; opacity: 0; }
	.anim-d2 { animation-delay: 1.4s; opacity: 0; }
	.anim-d3 { animation-delay: 2.2s; opacity: 0; }

	.reveal {
		opacity: 0;
		transform: translateY(30px);
		transition: opacity 1.2s cubic-bezier(0.12, 1, 0.2, 1),
					transform 1.2s cubic-bezier(0.12, 1, 0.2, 1);
	}
	.reveal.revealed {
		opacity: 1;
		transform: translateY(0);
	}

	/* ─── NAV ─── */
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: rgba(255, 255, 255, 0.88);
		backdrop-filter: blur(20px);
		border-bottom: 1px solid var(--border-light);
	}
	.nav-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 24px;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.nav-brand {
		display: flex;
		align-items: center;
		gap: 12px;
		text-decoration: none;
	}
	.nav-logo {
		width: 34px;
		height: 34px;
		border-radius: 9px;
		background: var(--navy);
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 800;
		font-size: 15px;
	}
	.nav-name {
		font-weight: 700;
		font-size: 15px;
		color: var(--navy);
		letter-spacing: -0.02em;
	}
	.nav-tagline {
		font-size: 11px;
		color: var(--text-muted);
	}
	.nav-cta {
		padding: 8px 20px;
		background: var(--navy);
		color: #fff;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 600;
		font-size: 13px;
		transition: background 0.2s, transform 0.2s;
	}
	.nav-cta:hover {
		background: var(--accent);
		transform: translateY(-1px);
	}

	/* ─── CONTAINER ─── */
	.fin-container {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 24px;
	}

	/* ─── SECTION HEADER (reuse) ─── */
	.section-header {
		text-align: center;
		margin-bottom: 48px;
	}
	.section-label {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 12px;
		font-weight: 600;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		margin-bottom: 12px;
	}
	.section-title {
		font-family: 'Playfair Display', Georgia, serif;
		font-size: clamp(1.4rem, 3.5vw, 2.2rem);
		font-weight: 500;
		letter-spacing: -0.02em;
		color: var(--navy);
		margin-bottom: 8px;
	}
	.section-title em {
		font-style: italic;
		color: var(--accent);
	}

	/* ─── BUTTONS ─── */
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 13px 28px;
		border-radius: 10px;
		font-weight: 600;
		font-size: 14px;
		text-decoration: none;
		transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
		cursor: pointer;
		border: none;
		font-family: inherit;
	}
	.btn-primary {
		background: var(--navy);
		color: #fff;
	}
	.btn-primary:hover {
		background: var(--accent);
		transform: translateY(-2px);
		box-shadow: 0 8px 30px rgba(37, 99, 235, 0.2);
	}
	.btn-outline {
		background: transparent;
		color: var(--navy);
		border: 1.5px solid var(--navy);
	}
	.btn-outline:hover {
		background: var(--navy);
		color: #fff;
		transform: translateY(-2px);
	}
	.btn-outline-light {
		background: transparent;
		color: #fff;
		border: 1.5px solid rgba(255, 255, 255, 0.4);
	}
	.btn-outline-light:hover {
		background: rgba(255, 255, 255, 0.1);
		border-color: rgba(255, 255, 255, 0.7);
		color: #fff;
		transform: translateY(-2px);
	}
	.btn-lg {
		padding: 15px 34px;
		font-size: 15px;
	}

	/* ─── HERO ─── */
	.fin-hero {
		text-align: center;
		padding: 80px 24px 60px;
		background: #fff;
	}
	.hero-bg {
		position: absolute;
		inset: 0;
		opacity: 0.018;
		background-image: radial-gradient(circle at 1px 1px, var(--navy) 1px, transparent 0);
		background-size: 40px 40px;
		pointer-events: none;
	}
	.fin-hero-content {
		position: relative;
		z-index: 1;
		max-width: 720px;
	}
	.fin-badge {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 18px;
		border-radius: 100px;
		background: var(--green-soft);
		border: 1px solid rgba(5, 150, 105, 0.15);
		margin-bottom: 28px;
		font-size: 13px;
		color: var(--green);
		font-weight: 600;
	}
	.fin-hero-title {
		font-family: 'Playfair Display', Georgia, serif;
		font-size: clamp(1.8rem, 5vw, 3.4rem);
		font-weight: 500;
		line-height: 1.15;
		letter-spacing: -0.02em;
